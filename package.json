{
  "name": "midas-app-automated-testing",
  "version": "1.0.0",
  "description": "Node.js test automation suite using Playwright and Cucumber",
  "main": "index.js",
  "scripts": {
    "test": "cucumber-js features --require step-definitions --require utils/setup.js",
    "test:headed": "set HEADED=true && npm test",
    "test:debug": "set DEBUG=true && npm test",
    "test:report": "cucumber-js features --require step-definitions --require utils/setup.js --format json:reports/cucumber-report.json",
    "posttest:report": "node utils/generate-html-report.js"
  },
  "keywords": [
    "playwright",
    "cucumber",
    "bdd",
    "automation",
    "testing"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@playwright/test": "^1.42.1",
    "@cucumber/cucumber": "^10.3.1",
    "playwright": "^1.42.1"
  },
  "devDependencies": {
    "cucumber-html-reporter": "^7.1.1",
    "@types/node": "^20.11.24",
    "eslint": "^8.57.0"
  }
}
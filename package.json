{
  "name": "midas-app-automated-testing",
  "version": "1.0.0",
  "description": "Node.js test automation suite using Playwright and Cucumber",
  "main": "index.js",
  "scripts": {
    "test": "cucumber-js features --require step-definitions --require utils/execution/setup.js",
    "test:smoke": "cucumber-js features/search.feature --require step-definitions --require utils/execution/setup.js --tags @smoke",
    "test:smoke:headed": "cross-env HEADED=true cucumber-js features/search.feature --require step-definitions --require utils/execution/setup.js --tags @smoke",
    "test:headed": "cross-env HEADED=true npm test",
    "test:debug": "cross-env DEBUG=true npm test",
    "test:report": "cucumber-js features --require step-definitions --require utils/execution/setup.js --format json:reports/cucumber-report.json",
    "posttest:report": "node utils/execution/generate-html-report.js",
    "record": "node utils/recording/start-recorder.js",
    "record:custom": "node utils/recording/test-recorder.js",
    "recordings": "node utils/recording/step-integrator.js list",
    "import:steps": "node utils/recording/step-integrator.js import",
    "import:feature": "node utils/recording/step-integrator.js feature"
  },
  "keywords": [
    "playwright",
    "cucumber",
    "bdd",
    "automation",
    "testing"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@cucumber/cucumber": "^10.3.1",
    "@playwright/test": "^1.42.1",
    "playwright": "^1.42.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.24",
    "cross-env": "^10.1.0",
    "cucumber-html-reporter": "^7.1.1",
    "eslint": "^8.57.0"
  }
}
